FROM golang:1.26.2 AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/benchmark ./cmd/benchmark
COPY indexer ./indexer

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /bin/benchmark ./cmd/benchmark

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /bin/benchmark /usr/local/bin/benchmark

ENV BENCHMARK_HOST=query-service

CMD ["benchmark"]